---
type NavItem = 'home' | 'train' | 'garden' | 'me';

interface Props {
  active?: NavItem;
}

const { active = 'home' } = Astro.props;

const stroke = '#4A3D4D';
const pinkMid = '#FFB7C5';
const lavMid = '#D5BDF5';
const lavSoft = '#EBDDFC';
const peachSoft = '#FFE0CC';
const peachMid = '#FFC299';
const butterMid = '#FFE38A';
const white = '#FFFFFF';

const items: { id: NavItem; label: string; href: string }[] = [
  { id: 'home',   label: 'Home',   href: '/' },
  { id: 'train',  label: 'Train',  href: '/workout/register' },
  { id: 'garden', label: 'Garden', href: '/garden' },
  { id: 'me',     label: 'Me',     href: '/me' },
];
---

<nav
  class="fixed bottom-0 left-0 right-0 z-40"
  style="
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top-left-radius: 28px;
    border-top-right-radius: 28px;
    padding: 14px 18px 28px;
    box-shadow: 0 -8px 24px rgba(255,105,180,0.08);
    border-top: 1px solid rgba(255,183,197,0.25);
  "
>
  <div class="flex justify-around items-center max-w-sm mx-auto">
    {items.map((item) => {
      const isActive = item.id === active;
      return (
        <a
          href={item.href}
          data-nav-id={item.id}
          data-astro-prefetch
          class="flex flex-col items-center gap-1 no-underline bloom-nav-link"
          style={isActive
            ? 'padding: 6px 14px; background: linear-gradient(135deg, #FFD4E080, #FFB7C580); border-radius: 14px;'
            : 'padding: 6px 10px;'
          }
          aria-current={isActive ? 'page' : undefined}
        >
          <span class="bloom-nav-icon" style={isActive ? 'display:flex' : 'display:flex; opacity:0.55'}>
            {item.id === 'home' && (
              <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 11 L12 4 L20 11 V20 H4 Z" fill={peachSoft} stroke={stroke} stroke-width="1.4" stroke-linejoin="round"/>
                <path d="M9.5 20 V14 H14.5 V20" fill={peachMid} stroke={stroke} stroke-width="1.4" stroke-linejoin="round"/>
                <circle cx="12" cy="8.5" r="0.8" fill={stroke}/>
              </svg>
            )}
            {item.id === 'train' && (
              <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 20 Q4 14 4 9 Q4 5 8 5 Q10.5 5 12 7.5 Q13.5 5 16 5 Q20 5 20 9 Q20 14 12 20 Z"
                  fill={pinkMid} stroke={stroke} stroke-width="1.4" stroke-linejoin="round"/>
                <path d="M7 10 H10 L11 8 L13 13 L14 10 H17"
                  stroke={white} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            )}
            {item.id === 'garden' && (
              <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                <ellipse cx="12" cy="6" rx="3" ry="4" fill={pinkMid} stroke={stroke} stroke-width="1.2"/>
                <ellipse cx="12" cy="18" rx="3" ry="4" fill={pinkMid} stroke={stroke} stroke-width="1.2"/>
                <ellipse cx="6" cy="12" rx="4" ry="3" fill={pinkMid} stroke={stroke} stroke-width="1.2"/>
                <ellipse cx="18" cy="12" rx="4" ry="3" fill={pinkMid} stroke={stroke} stroke-width="1.2"/>
                <circle cx="12" cy="12" r="3" fill={butterMid} stroke={stroke} stroke-width="1.2"/>
              </svg>
            )}
            {item.id === 'me' && (
              <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="8" r="4" fill={lavMid} stroke={stroke} stroke-width="1.4"/>
                <path d="M4 21 Q4 14 12 14 Q20 14 20 21 Z" fill={lavSoft} stroke={stroke} stroke-width="1.4" stroke-linejoin="round"/>
                <circle cx="10.5" cy="8" r="0.5" fill={stroke}/>
                <circle cx="13.5" cy="8" r="0.5" fill={stroke}/>
              </svg>
            )}
          </span>
          <span
            class="bloom-nav-label text-xs font-bold"
            style={isActive ? 'color: #FF8FAB;' : 'color: #8E7B92;'}
          >{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<script is:inline>
  function applyNavActive() {
    const path = window.location.pathname;
    const links = document.querySelectorAll('.bloom-nav-link');

    function getActiveId(p) {
      if (p === '/') return 'home';
      if (p.startsWith('/workout')) return 'train';
      if (p.startsWith('/garden')) return 'garden';
      if (p.startsWith('/me')) return 'me';
      return null;
    }

    const activeId = getActiveId(path);

    links.forEach(function(link) {
      const id = link.getAttribute('data-nav-id');
      const isActive = id === activeId;
      const icon = link.querySelector('.bloom-nav-icon');
      const label = link.querySelector('.bloom-nav-label');

      if (isActive) {
        link.style.padding = '6px 14px';
        link.style.background = 'linear-gradient(135deg, #FFD4E080, #FFB7C580)';
        link.style.borderRadius = '14px';
        link.setAttribute('aria-current', 'page');
        if (icon) icon.style.opacity = '1';
        if (label) label.style.color = '#FF8FAB';
      } else {
        link.style.padding = '6px 10px';
        link.style.background = 'transparent';
        link.style.borderRadius = '0';
        link.removeAttribute('aria-current');
        if (icon) icon.style.opacity = '0.55';
        if (label) label.style.color = '#8E7B92';
      }
    });
  }

  applyNavActive();
  document.addEventListener('astro:page-load', applyNavActive);
</script>
