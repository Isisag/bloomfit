---
import MainLayout from '@/layouts/MainLayout.astro';
import AuthGuard from '@/components/islands/AuthGuard';
import DashboardInit from '@/components/islands/DashboardInit';
import LogoutButton from '@/components/islands/LogoutButton';
---

<MainLayout title="BloomFit">
  <AuthGuard client:load requireAuth={true} />
  <DashboardInit client:load />

  <div
    class="min-h-screen flex flex-col"
    style="background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-bg) 30%, var(--color-bg) 100%)"
  >
    <!-- Header placeholder -->
    <div class="flex items-center justify-between px-6 pt-12 pb-4">
      <div>
        <p class="text-xs font-bold tracking-wider uppercase" style="color: var(--color-text-muted)">BloomFit</p>
        <h1 class="text-2xl font-bold mt-1" style="color: var(--color-text)">¡Hola! 👋</h1>
      </div>
      <LogoutButton client:load />
    </div>

    <!-- Flower placeholder -->
    <div class="flex-1 flex flex-col items-center justify-center gap-6 px-6">
      <div class="text-8xl" style="filter: drop-shadow(0 12px 24px rgba(255,105,180,0.2))">
        🌸
      </div>
      <div
        class="rounded-3xl p-6 w-full max-w-sm text-center"
        style="background: #fff; box-shadow: 0 8px 24px rgba(255,105,180,0.1);"
      >
        <p class="text-sm font-bold" style="color: var(--color-accent)">DAILY BLOOM</p>
        <p class="text-base font-bold mt-2" style="color: var(--color-text)">
          Tu flor crece cuando tú creces ✨
        </p>
      </div>

      <!-- CTA placeholder -->
      <button
        class="w-full max-w-sm py-4 rounded-2xl font-bold text-white text-base"
        style="background: #5A4A5C; box-shadow: 0 8px 18px rgba(90,74,92,0.28);"
      >
        ✿ Entrenar
      </button>

      <p class="text-sm" style="color: var(--color-text-muted)">
        Dashboard completo — próximamente F5
      </p>
    </div>
  </div>
</MainLayout>
