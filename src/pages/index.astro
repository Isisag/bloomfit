---
import MainLayout from '@/layouts/MainLayout.astro';
import AuthGuard from '@/components/islands/AuthGuard';
import DashboardInit from '@/components/islands/DashboardInit';
import LogoutButton from '@/components/islands/LogoutButton';
---

<MainLayout title="BloomFit">
  <AuthGuard client:load requireAuth={true} />
  <DashboardInit client:load />
  <div class="min-h-screen flex items-center justify-center bg-rose-50 relative">
    <div class="absolute top-4 right-4">
      <LogoutButton client:load />
    </div>
    <div class="text-center">
      <div class="text-5xl mb-4">🌸</div>
      <h1 class="text-2xl font-bold text-rose-400">BloomFit</h1>
      <p class="text-rose-300 mt-2 text-sm">Dashboard — próximamente</p>
    </div>
  </div>
</MainLayout>
