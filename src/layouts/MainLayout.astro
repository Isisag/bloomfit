---
import '../styles/global.css';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';

interface Props {
  title?: string;
}

const { title = 'BloomFit' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tu flor crece cuando tú creces" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Apply theme from localStorage before first paint to prevent flash -->
    <script is:inline>
      const t = localStorage.getItem('bloomfit-theme') || 'sakura';
      document.documentElement.setAttribute('data-theme', t);
    </script>
  </head>
  <body>
    <div class="fixed top-4 right-4 z-50 bg-white/80 backdrop-blur-sm rounded-2xl px-3 py-2 shadow-sm border" style="border-color: var(--color-border)">
      <ThemeToggle />
    </div>
    <slot />
  </body>
</html>
