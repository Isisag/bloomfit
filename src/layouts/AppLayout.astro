---
import '../styles/global.css';
import BottomNav from '@/components/ui/BottomNav.astro';

type NavItem = 'home' | 'train' | 'garden' | 'me';

interface Props {
  title?: string;
  activeNav?: NavItem;
}

const { title = 'BloomFit', activeNav = 'home' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tu flor crece cuando tú creces" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      const t = localStorage.getItem('bloomfit-theme') || 'sakura';
      document.documentElement.setAttribute('data-theme', t);
    </script>
  </head>
  <body style="padding-bottom: 88px;">
    <slot />
    <BottomNav active={activeNav} />
  </body>
</html>
